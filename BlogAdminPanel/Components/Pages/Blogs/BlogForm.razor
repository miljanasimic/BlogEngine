@page "/blogs/new"
@page "/blogs/edit/{Id:int}"

<h3>@(Id == 0 ? "New Blog" : "Edit Blog")</h3>
@if (editContext == null)
{
    <p>Loading...</p>
}
else
{
  <EditForm EditContext="editContext" OnValidSubmit="SaveBlog" FormName="BlogForm">
      <DataAnnotationsValidator />
      <ValidationSummary />

      <div class="mb-3">
          <label>Title</label>
          <InputText class="form-control" @bind-Value="blogModel.Title" />
          <ValidationMessage For="@(() => blogModel.Title)" />
      </div>

      <div class="mb-3">
          <label>Short Description</label>
          <InputTextArea class="form-control" @bind-Value="blogModel.ShortDescription" />
          <ValidationMessage For="@(() => blogModel.ShortDescription)" />
      </div>

      <div class="mb-3">
          <label>Content</label>
          <InputTextArea class="form-control" rows="8" @bind-Value="blogModel.Content" />
          <ValidationMessage For="@(() => blogModel.Content)" />
      </div>

      <div class="mb-3">
          <label>Language (2 chars)</label>
          <InputText class="form-control" @bind-Value="blogModel.Language" maxlength="2" />
          <ValidationMessage For="@(() => blogModel.Language)" />
      </div>

      <div class="mb-3">
          <label>Tags (comma-separated)</label>
          <InputText class="form-control" @bind-Value="TagsText" />
      </div>

      <div class="mb-3">
          <label>Author</label>
          <InputSelect class="form-select" @bind-Value="blogModel.AuthorId">
              <option value="">-- Select Author --</option>
              @foreach(var author in authors)
              {
                  <option value="@author.Id">@author.FirstName @author.LastName</option>
              }
          </InputSelect>
          <ValidationMessage For="@(() => blogModel.AuthorId)" />
      </div>

      <div class="mb-3">
        <label for="datePublished" class="form-label">Date Published</label>
        <InputDate @bind-Value="blogModel.DatePublished" class="form-control" id="datePublished" />
    </div>

      <button type="submit" class="btn btn-primary" disabled="@(!IsValid())">
      @(Id == 0 ? "Create" : "Update")
      </button>
      <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">
        Cancel
      </button>
  </EditForm>
}