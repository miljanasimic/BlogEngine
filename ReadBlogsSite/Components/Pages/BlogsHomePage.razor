@page "/"
@page "/blogs"
@using ReadBlogsSite.Components.Shared

<div class="m-4">

    <h2 class="mb-4">Welcome to Our Blog</h2>

    @if (isLoading)
    {
        <p>Loading blogs...</p>
    }
    else if (!blogs.Any() && string.IsNullOrEmpty(SelectedTag) && string.IsNullOrEmpty(SelectedLang))
    {
        <p>No blog posts available.</p>
    }
    else
    {
        <div class="row mb-4 gap-3">
            <div class="col-md-4">
                <select class="form-select" value="@SelectedTag" @onchange="OnTagFilterChanged">
                    <option value="">All tags</option>
                    @foreach(var tag in availableTags)
                    {
                        <option value="@tag.Id">@tag.Name</option>
                    }
                </select>

            </div>

            <div class="col-md-4">
                <select class="form-select" value="@SelectedLang" @onchange="OnLanguageFilterChanged">
                    <option value="">All languages</option>
                    @foreach(var lang in availableLanguages)
                    {
                        <option value="@lang">@lang</option>
                    }
                </select>
            </div>
        </div>

        <div class="row g-4">
            @if (!blogs.Any())
            {
                <div class="col-12">
                    <p>No blogs found for the selected filters.</p>
                </div>
            }
            else
            {
                @foreach (var blog in blogs)
                {
                    <div class="col-12 col-lg-6">

                        <div class="card h-100 shadow-sm">

                            <div class="card-body d-flex flex-column">

                                <h4 class="card-title">@blog.Title</h4>

                                <p class="text-muted mb-2">
                                    Published by <strong>@blog.AuthorName</strong>
                                    on @blog.DatePublished.Date.ToString("MMMM dd, yyyy")
                                </p>

                                <p class="card-text mb-3"
                                style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                    @blog.ShortDescription
                                </p>

                                @if (blog.Tags != null && blog.Tags.Any())
                                {
                                    <div class="mb-3 d-flex flex-wrap gap-1">
                                        @foreach (var tag in blog.Tags)
                                        {
                                            <TagItem TagId="@tag.Id" Name="@tag.Name" />
                                        }
                                    </div>
                                }

                                <div class="mt-auto">
                                    <button class="btn btn-primary"
                                            @onclick="() => OpenBlogDetails(blog.Id)">
                                        Read full article
                                    </button>
                                </div>

                            </div>

                        </div>

                    </div>
                }
            }

        </div>
    }

</div>